# Dockerfile for dev — includes full Go toolchain + Air for hot-reload.
# DO NOT use for production image (use docker/Dockerfile).
FROM golang:1.23-alpine
WORKDIR /app
RUN apk add --no-cache git
RUN go install github.com/air-verse/air@latest
COPY go.mod go.sum ./
RUN go mod download
COPY . .
CMD ["air"]
