# Dockerfile khusus dev — bawa full Go toolchain + Air untuk hot-reload.
# JANGAN dipakai untuk production image (pakai docker/Dockerfile).
FROM golang:1.23-alpine
WORKDIR /app
RUN apk add --no-cache git
RUN go install github.com/air-verse/air@latest
COPY go.mod go.sum ./
RUN go mod download
COPY . .
CMD ["air"]
