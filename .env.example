# --- Server ---
APP_ENV=development
APP_PORT=8080
SHUTDOWN_TIMEOUT=30s
APP_TIMEZONE=Asia/Jakarta

# --- Database (PostgreSQL via GORM, AutoMigrate) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=psyche_assessment
DB_SSLMODE=disable

# --- Redis (idempotency key, rate limit, Asynq broker) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Object Storage (Cloudflare R2 prod / MinIO dev — same code endpoint) ---
# R2: endpoint format is https://<ACCOUNT_ID>.r2.cloudflarestorage.com, obtain from Cloudflare dashboard
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=your-personas-reports
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_PATH_STYLE=true

# --- SMTP / Mailer (Mailpit for local dev via docker-compose, Brevo for staging/production) ---
# If using local Mailpit (default docker-compose.dev.yml), leave as is.
# If using Brevo, change host/port/user/password according to SMTP credentials in your Brevo dashboard
# (Settings > SMTP & API > SMTP).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourpersonas.com

# --- Gemini API ---
GEMINI_API_KEY=
# MUST be a specific pinned version (e.g. gemini-2.5-pro-001), DO NOT use auto-updating alias —
# alias behavior/format can change without deployment. Test new versions in staging first.
GEMINI_MODEL=
GEMINI_MAX_CONCURRENT=10
# Aggregate daily token cap across ALL users — the cost guardrail
# against viral spikes/distributed abuse. 0 or unset = cap disabled (dev default).
# Unit is raw tokens (not USD): derive from target cost/day ÷ model price per token,
# e.g. max $500/day. When exhausted, submits gracefully fall back to static
# results (no error) until the WIB day rolls over.
GEMINI_DAILY_TOKEN_BUDGET=0

# --- Auth ---
JWT_SECRET=changeme-generate-a-real-random-secret
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=720h


OTP_RESEND_COOLDOWN_SECONDS=60
OTP_RESEND_DAILY_MAX=5
IDEMPOTENCY_TTL_SUBMIT=24h

# --- Bot Protection ---
TURNSTILE_SECRET_KEY=

# --- CORS (comma-separated frontend origins — NEVER a wildcard "*") ---
ALLOWED_ORIGINS=http://localhost:3000

# Comma-separated CIDRs (or bare IPs, treated as /32) of proxies allowed to
# set X-Forwarded-For — c.RealIP() only trusts that header when the
# immediate connection comes from one of these ranges, otherwise it uses the
# raw TCP peer address. Leave EMPTY for local dev (talking to the app
# directly, no proxy in front). In production behind docker-compose.prod.yml's
TRUSTED_PROXIES=

# --- i18n ---
DEFAULT_LOCALE=en
