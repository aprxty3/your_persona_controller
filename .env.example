# Copy file ini jadi .env dan isi sesuai environment kamu.
# Default di bawah ini sudah cocok untuk docker-compose.dev.yml (MinIO + Mailpit lokal).

# --- Server ---
APP_ENV=development
APP_PORT=8080
SHUTDOWN_TIMEOUT=30s
APP_TIMEZONE=Asia/Jakarta

# --- Database (PostgreSQL via GORM, AutoMigrate — lihat AGENTS.md) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=psyche_assessment
DB_SSLMODE=disable

# --- Redis (idempotency key, rate limit, Asynq broker) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Object Storage (Cloudflare R2 prod / MinIO dev — endpoint code sama, lihat PRD Section 9) ---
# R2: endpoint formatnya https://<ACCOUNT_ID>.r2.cloudflarestorage.com, dapatkan dari dashboard Cloudflare
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=your-personas-reports
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_PATH_STYLE=true

# --- SMTP / Mailer (Mailpit untuk dev lokal via docker-compose, Brevo untuk staging/production) ---
# Kalau pakai Mailpit lokal (default docker-compose.dev.yml), biarkan seperti di bawah.
# Kalau pakai Brevo, ganti host/port/user/password sesuai kredensial SMTP di dashboard Brevo kamu
# (Settings > SMTP & API > SMTP).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourpersonas.com

# --- Gemini API ---
GEMINI_API_KEY=
# WAJIB versi pinned spesifik (mis. gemini-2.5-pro-001), JANGAN alias auto-update —
# alias bisa berubah behavior/format tanpa deploy dari kita. Tes versi baru di staging dulu.
GEMINI_MODEL=
GEMINI_MAX_CONCURRENT=10

# --- Auth ---
JWT_SECRET=changeme-generate-a-real-random-secret
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=720h
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_RESEND_DAILY_MAX=5
IDEMPOTENCY_TTL_SUBMIT=24h

# --- Bot Protection ---
TURNSTILE_SECRET_KEY=

# --- i18n ---
DEFAULT_LOCALE=en
# MVP scope: en (default), id. Locale lain nyusul pas production — lihat PRD Epic I.
