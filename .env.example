# --- Server ---
APP_ENV=development
APP_PORT=8080
SHUTDOWN_TIMEOUT=30s
APP_TIMEZONE=Asia/Jakarta

# --- Database (PostgreSQL via GORM, AutoMigrate) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=psyche_assessment
DB_SSLMODE=disable

# --- Redis (idempotency key, rate limit, Asynq broker) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Object Storage (Cloudflare R2 prod / MinIO dev — same code endpoint) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=your-personas-reports
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_PATH_STYLE=true

# --- SMTP / Mailer (Mailpit for local dev via docker-compose, Brevo for staging/production) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourpersonas.com

# --- Gemini API ---
GEMINI_API_KEY=
GEMINI_MODEL=
GEMINI_MAX_CONCURRENT=10
GEMINI_DAILY_TOKEN_BUDGET=0
GEMINI_TEMPERATURE=0.6

# --- Auth ---
JWT_SECRET=changeme-generate-a-real-random-secret

# --- Worker (Asynq) ---
WORKER_PDF_CONCURRENCY=2
WORKER_IO_CONCURRENCY=8

# --- Bot Protection ---
TURNSTILE_SECRET_KEY=

# --- CORS (comma-separated frontend origins — NEVER a wildcard "*") ---
ALLOWED_ORIGINS=http://localhost:3000

# Comma-separated CIDRs (or bare IPs, treated as /32) of proxies allowed to
# set X-Forwarded-For — c.RealIP() only trusts that header when the immediate
# TCP connection comes from one of these ranges; otherwise it uses the raw
# peer address, so a spoofed header from anywhere else is ignored. Prevents
# faking the client IP to dodge per-IP rate limiting / Turnstile checks.
# Leave EMPTY when nothing sits in front of the app (local dev, or exposing
# the API directly). In production behind docker-compose.prod.yml's bundled
# Caddy, use that compose file's pinned network subnet: 172.28.0.0/16 — see
# the `networks:` block at the top of docker-compose.prod.yml for why it's
# pinned instead of relying on Docker's auto-assigned bridge range. If a
# Cloudflare-proxied domain is added in front of Caddy later, use Cloudflare's
# published IPv4/IPv6 ranges instead (cloudflare.com/ips) — those change over
# time and are NOT hardcoded here.
TRUSTED_PROXIES=

# --- i18n ---
DEFAULT_LOCALE=en
